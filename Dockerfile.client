# syntax=docker/dockerfile:1

FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/nam-tcp-client ./cmd/client

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /out/nam-tcp-client /usr/local/bin/nam-tcp-client

ENTRYPOINT ["nam-tcp-client"]

CMD ["help"]
